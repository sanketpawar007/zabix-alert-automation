# ══════════════════════════════════════════════════════════════════════════════
# JUNIPER AI ALERT SYSTEM - CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER SELECTION
# ─────────────────────────────────────────────────────────────────────────────
# Choose which providers to use (change these to switch providers)

# AI Provider: ollama (free, local) or claude (paid, production)
PROVIDER_AI=ollama

# Messaging Provider: telegram (free) or twilio (paid, WhatsApp)
PROVIDER_MESSAGING=telegram

# Monitoring Provider: zabbix (production) or simulator (testing)
PROVIDER_MONITORING=zabbix

# ─────────────────────────────────────────────────────────────────────────────
# FLASK APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
FLASK_DEBUG=False

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# This MUST match the secret in your Zabbix webhook configuration
WEBHOOK_SECRET=your-64-character-hex-secret-here

# Minimum alert severity to process (Not classified, Information, Warning, Average, High, Disaster)
MIN_SEVERITY=High

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA AI SETTINGS (when PROVIDER_AI=ollama)
# ─────────────────────────────────────────────────────────────────────────────
# Install Ollama from: https://ollama.ai
# Then run: ollama pull llama3.2

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=60
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=400

# ─────────────────────────────────────────────────────────────────────────────
# CLAUDE AI SETTINGS (when PROVIDER_AI=claude)
# ─────────────────────────────────────────────────────────────────────────────
# Get API key from: https://console.anthropic.com/api-keys

ANTHROPIC_API_KEY=sk-ant-api03-xxxxx...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=400

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM SETTINGS (when PROVIDER_MESSAGING=telegram)
# ─────────────────────────────────────────────────────────────────────────────
# Setup instructions:
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the bot token
# 4. Start a chat with your bot and send any message
# 5. Get your chat ID from: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_IDS=123456789,987654321
TELEGRAM_TIMEOUT=10
TELEGRAM_PARSE_MODE=Markdown

# ─────────────────────────────────────────────────────────────────────────────
# TWILIO WHATSAPP SETTINGS (when PROVIDER_MESSAGING=twilio)
# ─────────────────────────────────────────────────────────────────────────────
# Get credentials from: https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_32_character_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_RECIPIENTS=whatsapp:+1234567890,whatsapp:+9876543210

# ─────────────────────────────────────────────────────────────────────────────
# MICROSOFT TEAMS SETTINGS (when PROVIDER_MESSAGING=teams) - RECOMMENDED
# ─────────────────────────────────────────────────────────────────────────────
# Privacy: ✅ Enterprise-grade - stays within your Microsoft tenant
# Cost: FREE (included with Microsoft 365)
#
# Setup:
# 1. Open Microsoft Teams
# 2. Go to channel → "..." → Connectors → Incoming Webhook
# 3. Name it "Juniper Alerts" and create
# 4. Copy the webhook URL

TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/xxxxx
TEAMS_TIMEOUT=10

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP) SETTINGS (when PROVIDER_MESSAGING=email) - RECOMMENDED
# ─────────────────────────────────────────────────────────────────────────────
# Privacy: ✅ Fully private if using internal SMTP server
# Cost: FREE (using existing mail server)

SMTP_SERVER=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USERNAME=alerts@yourcompany.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_FROM_EMAIL=juniper-alerts@yourcompany.com
ALERT_RECIPIENTS=network-team@yourcompany.com,noc@yourcompany.com

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/alert-service.log

# ─────────────────────────────────────────────────────────────────────────────
# SIMULATOR SETTINGS (when PROVIDER_MONITORING=simulator)
# ─────────────────────────────────────────────────────────────────────────────
SIMULATOR_REQUIRE_AUTH=False
